{
  "buildCommand": "npm run build",
  "outputDirectory": "_site",
  "framework": "eleventy",
  "rewrites": [
    { "source": "/admin/(.*)", "destination": "/admin/$1" }
  ],
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ]
}